{
  "name": "test-results-reporter",
  "version": "1.0.0",
  "description": "Aggregates JUnit XML, Jest JSON, and pytest JSON test results and posts a clean PR comment",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --no-cache",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "fast-xml-parser": "^4.3.6",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
